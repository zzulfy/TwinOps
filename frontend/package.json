{
  "name": "twin-ops",
  "version": "1.0.0",
  "description": "数据中心数字孪生智能运维平台 - 国家电网设备监控与预测",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "dev": "vite",
    "preview": "vite preview",
    "smoke:shell": "node scripts/smoke/check-shell-readiness.mjs",
    "smoke:analysis-trigger": "node scripts/smoke/check-analysis-trigger.mjs",
    "smoke:auth-expiry": "node scripts/smoke/check-auth-expiry.mjs",
    "smoke:analysis-auto-refresh": "node scripts/smoke/check-analysis-auto-refresh.mjs",
    "smoke:alarm-real-data": "node scripts/smoke/check-alarm-panel-real-data.mjs",
    "smoke:alarm-manual-scroll": "node scripts/smoke/check-alarm-scroll-smooth.mjs",
    "build-only": "vite build",
    "type-check": "tsc -p tsconfig.react.json --noEmit",
    "type-check:react": "tsc -p tsconfig.react.json --noEmit",
    "lint": "eslint --fix --ext .js,.jsx,.ts,.tsx src",
    "format": "prettier --write src/",
    "lint:style": "stylelint **/*.{html,css,sass,scss} --fix",
    "prettier:format": "prettier --config .prettierrc.cjs  --ext .js,.jsx,.ts,.tsx src --write"
  },
  "dependencies": {
    "@tweenjs/tween.js": "19.0.0",
    "animate.css": "^4.1.1",
    "autofit.js": "^3.0.7",
    "axios": "^1.13.3",
    "cheerio": "^1.2.0",
    "echarts": "^5.4.3",
    "gsap": "^3.12.5",
    "lodash": "^4.17.21",
    "mitt": "^3.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.6",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "eslint": "^8.39.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "npm-run-all2": "^6.1.1",
    "postcss": "^8.4.23",
    "postcss-html": "^1.5.0",
    "prettier": "^2.8.8",
    "puppeteer": "^24.36.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.77.8",
    "stylelint": "^14.16.1",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recess-order": "^3.0.0",
    "stylelint-config-recommended-scss": "^8.0.0",
    "stylelint-config-standard": "^29.0.0",
    "stylelint-config-standard-scss": "^6.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-eslint": "^1.8.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "yarn lint",
      "yarn prettier:format"
    ],
    "*.{html,css,sass,scss}": [
      "yarn lint:style"
    ]
  },
  "resolutions": {
    "bin-wrapper": "npm:bin-wrapper-china"
  }
}
